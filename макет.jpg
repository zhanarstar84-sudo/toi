<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Талгат - 50 лет</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; background: #000; overflow: hidden; font-family: 'Arial', sans-serif; }
        .wrapper { position: relative; width: 100%; max-width: 500px; margin: 0 auto; height: 100vh; background: url('макет.jpg') no-repeat center center; background-size: cover; }
        
        .music-btn { position: absolute; top: 20px; right: 20px; background: rgba(212,175,55,0.3); border: 1px solid #d4af37; border-radius: 50%; width: 45px; height: 45px; color: #d4af37; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 20; }
        .lang-btns { position: absolute; top: 20px; left: 20px; display: flex; gap: 10px; z-index: 20; }
        .lang-btns button { background: rgba(0,0,0,0.6); border: 1px solid #d4af37; color: #fff; padding: 5px 12px; cursor: pointer; border-radius: 5px; font-size: 12px; }

        /* Адрес и дата сверху, чтобы не мешали фото */
        .info-box { position: absolute; top: 15%; left: 50%; transform: translateX(-50%); width: 90%; text-align: center; color: #fff; text-shadow: 2px 2px 5px rgba(0,0,0,1); }
        .info-box h2 { font-size: 22px; margin: 5px 0; color: #d4af37; text-transform: uppercase; }
        .info-box p { font-size: 16px; margin: 2px 0; font-weight: bold; }

        /* Таймер в самом низу над кнопкой */
        .timer-box { position: absolute; bottom: 95px; left: 50%; transform: translateX(-50%); width: 100%; text-align: center; color: #fff; }
        .timer-label { font-size: 11px; color: #d4af37; letter-spacing: 2px; margin-bottom: 5px; text-transform: uppercase; font-weight: bold; }
        .countdown { display: flex; justify-content: center; gap: 15px; }
        .time-item { display: flex; flex-direction: column; align-items: center; background: rgba(0,0,0,0.5); padding: 5px; border-radius: 5px; min-width: 50px; }
        .time-num { font-size: 24px; font-weight: bold; line-height: 1; }
        .time-text { font-size: 9px; color: #d4af37; text-transform: uppercase; margin-top: 3px; }

        .wa-btn { position: absolute; bottom: 25px; left: 50%; transform: translateX(-50%); width: 85%; background: linear-gradient(45deg, #d4af37, #f9f0b5); padding: 14px; text-align: center; border-radius: 30px; text-decoration: none; color: #000; font-weight: bold; font-size: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.6); z-index: 10; border: 1px solid #fff; }
    </style>
</head>
<body>

    <div class="wrapper">
        <div class="lang-btns">
            <button onclick="changeLang('kz')">ҚАЗ</button>
            <button onclick="changeLang('ru')">РУС</button>
        </div>

        <div class="music-btn" onclick="toggleMusic()">
            <span id="music-icon">♪</span>
        </div>

        <div class="info-box">
            <h2 id="date-text">14 МАУСЫМ, 16:00</h2>
            <p id="address-text">Қорғалжын тас жолы</p>
        </div>

        <div class="timer-box">
            <div class="timer-label" id="t-title">ТОЙҒА ДЕЙІН ҚАЛДЫ:</div>
            <div class="countdown">
                <div class="time-item"><span class="time-num" id="days">00</span><span class="time-text" id="t-d">күн</span></div>
                <div class="time-item"><span class="time-num" id="hours">00</span><span class="time-text" id="t-h">сағат</span></div>
                <div class="time-item"><span class="time-num" id="mins">00</span><span class="time-text" id="t-m">мин</span></div>
                <div class="time-item"><span class="time-num" id="secs">00</span><span class="time-text" id="t-s">сек</span></div>
            </div>
        </div>

        <a href="https://wa.me/77015201111?text=Сәлеметсіз бе! Мерейтойға келетінімді растаймын." class="wa-btn" id="wa-text">ҚАТЫСУЫҢЫЗДЫ РАСТАУ</a>
    </div>

    <audio id="bgMusic" loop>
        <source src="music.mp3" type="audio/mpeg">
    </audio>

    <script>
        const music = document.getElementById('bgMusic');
        function toggleMusic() {
            if (music.paused) { music.play(); document.getElementById('music-icon').innerText = '⏸'; }
            else { music.pause(); document.getElementById('music-icon').innerText = '♪'; }
        }

        function changeLang(lang) {
            const t = {
                ru: { 
                    title: "ДО ТОЯ ОСТАЛОСЬ:", d: "дн", h: "час", m: "мин", s: "сек", 
                    btn: "ПОДТВЕРДИТЬ ПРИСУТСТВИЕ", date: "14 ИЮНЯ, 16:00", addr: "Кургальжинское шоссе" 
                },
                kz: { 
                    title: "ТОЙҒА ДЕЙІН ҚАЛДЫ:", d: "күн", h: "сағат", m: "мин", s: "сек", 
                    btn: "ҚАТЫСУЫҢЫЗДЫ РАСТАУ", date: "14 МАУСЫМ, 16:00", addr: "Қорғалжын тас жолы" 
                }
            };
            document.getElementById('t-title').innerText = t[lang].title;
            document.getElementById('t-d').innerText = t[lang].d;
            document.getElementById('t-h').innerText = t[lang].h;
            document.getElementById('t-m').innerText = t[lang].m;
            document.getElementById('t-s').innerText = t[lang].s;
            document.getElementById('wa-text').innerText = t[lang].btn;
            document.getElementById('date-text').innerText = t[lang].date;
            document.getElementById('address-text').innerText = t[lang].addr;
        }

        const eventDate = new Date("June 14, 2026 16:00:00").getTime();
        setInterval(() => {
            const now = new Date().getTime();
            const diff = eventDate - now;
            if (diff > 0) {
                document.getElementById('days').innerText = Math.floor(diff / (1000 * 60 * 60 * 24));
                document.getElementById('hours').innerText = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                document.getElementById('mins').innerText = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                document.getElementById('secs').innerText = Math.floor((diff % (1000 * 60)) / 1000);
            }
        }, 1000);
    </script>
</body>
</html>